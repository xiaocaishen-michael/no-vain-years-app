{
  "name": "no-vain-years-app",
  "version": "0.1.0",
  "private": true,
  "description": "「不虚此生」跨端前端 monorepo（pnpm workspace + Expo + NativeWind）",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter native dev",
    "web": "pnpm --filter native web",
    "build:web": "pnpm --filter native build:web",
    "ios": "pnpm --filter native ios",
    "android": "pnpm --filter native android",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "api:gen": "pnpm --filter @nvy/api-client api:gen",
    "api:gen:dev": "pnpm --filter @nvy/api-client api:gen:dev",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "lint-staged": "^15.2.10",
    "playwright": "^1.60.0",
    "prettier": "^3.3.3",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.59.3"
  }
}
